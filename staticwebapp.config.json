{
  "routes": [
    {
      "route": "/hanamizuki",
      "rewrite": "/hanamizuki/index.html"
    },
    {
      "route": "/hanamizuki/*",
      "rewrite": "/hanamizuki/index.html"
    },
    {
      "route": "/nagaken",
      "rewrite": "/nagaken/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/hanamizuki/*", "/nagaken/*"]
  }
}
