{
  "routes": [
    {
      "route": "/hanamizuki",
      "rewrite": "/hanamizuki/index.html"
    },
    {
      "route": "/hanamizuki/images/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/nagaken",
      "rewrite": "/nagaken/index.html"
    },
    {
      "route": "/nagaken-face",
      "rewrite": "/nagaken-face/index.html"
    },
    {
      "route": "/nagaken-face/images/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/GembaAI_Service",
      "rewrite": "/GembaAI_Service/index.html"
    },
    {
      "route": "/kyuyo",
      "rewrite": "/kyuyo/index.html"
    },
    {
      "route": "/kensetsu-invoice",
      "rewrite": "/kensetsu-invoice/index.html"
    },
    {
      "route": "/kensetsu-invoice/images/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/kokorocare",
      "rewrite": "/kokorocare/index.html"
    },
    {
      "route": "/kokorocare/images/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/gemba-academy",
      "rewrite": "/gemba-academy/index.html"
    },
    {
      "route": "/gemba-academy/images/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/invoice-receipt",
      "rewrite": "/invoice-receipt/index.html"
    },
    {
      "route": "/invoice-receipt/images/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/hanamizuki-server",
      "rewrite": "/hanamizuki-server/index.html"
    },
    {
      "route": "/hanamizuki-server/images/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/hanamizuki/images/*.png",
      "/hanamizuki/images/*.jpg",
      "/hanamizuki/images/*.pdf",
      "/hanamizuki/*.html",
      "/nagaken/images/*.png",
      "/nagaken/images/*.jpg",
      "/nagaken/*.html",
      "/nagaken-face/images/*.png",
      "/nagaken-face/images/*.jpg",
      "/nagaken-face/*.html",
      "/GembaAI_Service/*.html",
      "/GembaAI_Service/*.css",
      "/GembaAI_Service/screenshots/*.png",
      "/kensetsu-invoice/*.html",
      "/kensetsu-invoice/*.css",
      "/kensetsu-invoice/*.js",
      "/kensetsu-invoice/images/*.png",
      "/kensetsu-invoice/images/*.jpg",
      "/kokorocare/*.html",
      "/kokorocare/*.css",
      "/kokorocare/*.js",
      "/kokorocare/images/*.png",
      "/kokorocare/images/*.jpg",
      "/kyuyo/*.html",
      "/gemba-academy/*.html",
      "/gemba-academy/*.css",
      "/gemba-academy/*.js",
      "/gemba-academy/images/*.png",
      "/gemba-academy/images/*.jpg",
      "/hanamizuki-server/*.html",
      "/hanamizuki-server/images/*.png",
      "/hanamizuki-server/images/*.jpg",
      "/*.png",
      "/*.jpg",
      "/*.pdf",
      "/*.html"
    ]
  }
}
