{
  "routes": [
    {
      "route": "/hanamizuki",
      "rewrite": "/hanamizuki/index.html"
    },
    {
      "route": "/hanamizuki/images/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/nagaken",
      "rewrite": "/nagaken/index.html"
    },
    {
      "route": "/GembaAI_Service",
      "rewrite": "/GembaAI_Service/index.html"
    },
    {
      "route": "/GembaAI_Service/",
      "rewrite": "/GembaAI_Service/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/hanamizuki/images/*.png",
      "/hanamizuki/images/*.jpg",
      "/hanamizuki/images/*.pdf",
      "/hanamizuki/*.html",
      "/nagaken/images/*.png",
      "/nagaken/images/*.jpg",
      "/nagaken/*.html",
      "/GembaAI_Service/*.html",
      "/GembaAI_Service/*.css",
      "/*.png",
      "/*.jpg",
      "/*.pdf",
      "/*.html"
    ]
  }
}
